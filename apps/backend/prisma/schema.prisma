// Prisma Schema - Dal
// Kritik işlemler $transaction ile atomic yapılır

generator client {
  provider = "prisma-client-js"
}

// ER diagram otomasyonu için scripts/generate-er-diagram.js kullanılır
// (sıfır dependency, Mermaid markdown çıktısı). CI'da nightly + push'ta
// docs/architecture/er-diagram.md güncellenir. Lokal'de: npm run db:erd

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Currency {
  TRY
  USD
  EUR
  GBP
}

enum SubscriberKind {
  EDUCATOR
  TENANT
}

enum SubscriptionTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum UserRole {
  ADMIN
  EDUCATOR
  CANDIDATE
  WORKER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_EDUCATOR_APPROVAL
  REJECTED
}

enum AttemptStatus {
  IN_PROGRESS
  PAUSED
  SUBMITTED
  TIMEOUT
  EXPIRED
}

enum TestStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum PurchaseStatus {
  ACTIVE
  REFUNDED
  EXPIRED
}

enum AuditAction {
  PURCHASE
  REFUND_REQUESTED
  REFUND_RESOLVED
  TEST_PUBLISHED
  TEST_UNPUBLISHED
  PRICE_CHANGED
  OBJECTION_CREATED
  OBJECTION_ANSWERED
  EDUCATOR_APPROVED
  EDUCATOR_REJECTED
  EDUCATOR_SUSPENDED
  EDUCATOR_UNSUSPENDED
  DISCOUNT_CREATED
  REVIEW_CREATED
  SUBMIT_ATTEMPT
  SUBMIT_ANSWER
  NOTIFICATIONS_DISABLED
  EMAIL_SENT
  OBJECTION_ESCALATED
  EMAIL_FAILED
  REFUND_APPROVED
  REFUND_REJECTED
  REVIEW_UPSERTED
  EXAMTYPE_CREATED
  TOPIC_CREATED
  CONTRACT_ACCEPTED
  EDUCATOR_PROFILE_UPDATED
  EXAMTYPE_UPDATED
  EXAMTYPE_DELETED
  TOPIC_UPDATED
  TOPIC_DELETED
  CSP_VIOLATION
  SUSPICIOUS_RATE_LIMIT
  AUTH_MFA_ENABLED
  AUTH_MFA_DISABLED
  AUTH_MFA_RECOVERY_USED
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAIL
  USER_ROLE_CHANGED
  USER_SUSPENDED
  USER_DELETED
  ADMIN_SETTINGS_UPDATED
  PAYOUT_PROCESSED
  BACKUP_RUN
  WEBHOOK_RECEIVED
  WEBHOOK_REJECTED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  // ── Email trafiği audit eventleri ───────────────────────────────────
  EMAIL_PROVIDER_CREATED
  EMAIL_PROVIDER_UPDATED
  EMAIL_PROVIDER_DELETED
  EMAIL_PROVIDER_TESTED
  EMAIL_KILL_SWITCH_CHANGED
  EMAIL_SUPPRESSION_ADDED
  EMAIL_SUPPRESSION_REMOVED
  EMAIL_TEMPLATE_UPDATED
  EMAIL_RETRY_TRIGGERED
  EMAIL_PREFERENCES_UPDATED
  EMAIL_UNSUBSCRIBE
}

// ── Email Trafiği Enums ─────────────────────────────────────────────────────

enum EmailQueue {
  CRITICAL // şifre sıfırlama, ödeme makbuzu, iade onayı, hesap güvenliği
  NOTIFY // soru itirazı sonucu, canlı oturum daveti, yeni inceleme
  BULK // haftalık digest, kampanya, duyuru
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  BOUNCED
  COMPLAINED
  FAILED
  SUPPRESSED // SuppressedEmail eşleşmesi nedeniyle gönderilmedi
  BLOCKED_BY_PREFS // kullanıcı tercihiyle reddedildi
  BLOCKED_BY_ADMIN // admin kill switch
  DEAD_LETTER // tüm retry'lar tükendi
}

enum EmailEventType {
  QUEUED
  SENDING
  SENT
  DELIVERED
  BOUNCED
  HARD_BOUNCED
  SOFT_BOUNCED
  COMPLAINED
  OPENED
  CLICKED
  FAILED
  RETRYING
  SUPPRESSED
  BLOCKED
}

enum EmailProviderKind {
  BREVO_API
  SMTP
  CONSOLE // dev/test
}

enum SuppressionReason {
  HARD_BOUNCE
  REPEATED_SOFT_BOUNCE
  SPAM_COMPLAINT
  UNSUBSCRIBE
  MANUAL_BLOCK
  INVALID_ADDRESS
}

// ── İçerik Moderasyonu enum'ları ─────────────────────────────────────────────

enum ModerationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ESCALATED
}

enum ModerationCategory {
  HATE_SPEECH
  VIOLENCE
  SEXUAL_CONTENT
  SELF_HARM
  HARASSMENT
  ILLEGAL
  PROFANITY
  SPAM
  MISINFORMATION
  PERSONAL_DATA
  COPYRIGHT
  OTHER
}

enum ModerationProvider {
  CLAUDE
  RULE_BASED
  MANUAL
}

enum EducatorRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ModerationActionType {
  WARN
  CONTENT_REMOVED
  ACCOUNT_SUSPENDED
  ACCOUNT_BANNED
  ESCALATED_TO_ADMIN
}

enum ObjectionStatus {
  OPEN
  ANSWERED
  ESCALATED
}

enum ContractType {
  CANDIDATE       // Üyelik / Kullanım Sözleşmesi — kayıt sırasında her kullanıcıya
  EDUCATOR        // Eğitici Hizmet Sözleşmesi — RegisterEducator'da, komisyon + IP/telif
  PRIVACY         // KVKK Aydınlatma Metni — kayıt sırasında (Sprint 14)
  DISTANCE_SALE   // Mesafeli Satış Sözleşmesi + Ön Bilgilendirme — her satın almada (Sprint 14)
}

// Reklam satın alma hedef türü: belirli test paketi veya eğiticinin kendisi
enum AdTargetType {
  TEST
  EDUCATOR
}

// --- Multi-tenant foundation ---

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  examTests            ExamTest[]
  purchases            Purchase[]
  adPurchases          AdPurchase[]
  subscriptions        Subscription[]
  testPackages         TestPackage[]
  packageViews         PackageView[]
  emailProviderConfigs EmailProviderConfig[]
  emailTemplates       EmailTemplate[]
  emailLogs            EmailLog[]
  emailEvents          EmailEvent[]
  suppressedEmails     SuppressedEmail[]
  blockedTerms         BlockedTerm[]
  moderationResults    ModerationResult[]
  moderationViolations ModerationViolation[]
  moderationActions    ModerationAction[]
  educatorRiskScores   EducatorRiskScore[]

  @@map("tenants")
}

// --- Marketplace / Exam domain ---

model User {
  id                              String     @id @default(uuid())
  email                           String     @unique
  username                        String     @unique
  // Eğitici kayıt akışında zorunlu; aday için opsiyonel.
  // username brand-display için kullanılır; firstName/lastName resmi adlandırma içindir.
  firstName                       String?
  lastName                        String?
  passwordHash                    String
  // Google OAuth ile bağlanmışsa Google'ın "sub" alanı; e-posta ile eşleştirme yapılır
  googleId                        String?    @unique
  bio                             String?
  role                            UserRole   @default(CANDIDATE)
  status                          UserStatus @default(ACTIVE)
  educatorApprovedAt              DateTime?
  // Admin tarafından reddedilme — eğitici başvurusu reddedildiyse sebep ve zaman
  rejectionReason                 String?
  rejectedAt                      DateTime?
  lastLoginAt                     DateTime?
  passwordResetToken              String?    @unique
  passwordResetTokenExpiresAt     DateTime?
  // Email doğrulama — yeni kayıtların onboarding adımı (aday e-postası tıklama ile aktive edilir)
  emailVerified                   Boolean    @default(false)
  emailVerificationToken          String?    @unique
  emailVerificationTokenExpiresAt DateTime?
  metadata                        Json?
  twoFactorEnabled                Boolean    @default(false)
  twoFactorSecret                 String? // AES-GCM encrypted; ASLA plain
  twoFactorRecovery               String[]   @default([]) // bcrypted code'lar
  twoFactorEnabledAt              DateTime?
  preferredCurrency               Currency   @default(TRY)
  preferredLocale                 String     @default("tr-TR")
  // ── Email trafiği tercih sistemi ────────────────────────────────────
  // marketing, productUpdates, weeklyDigest, reviewNotifications,
  // objectionUpdates, liveSessionInvites, refundUpdates
  emailPreferences                Json       @default("{\"marketing\":false,\"productUpdates\":true,\"weeklyDigest\":true,\"reviewNotifications\":true,\"objectionUpdates\":true,\"liveSessionInvites\":true,\"refundUpdates\":true}")
  emailUnsubscribeToken           String?    @unique
  // Tek aktif oturum kuralı — her başarılı login yeni bir sid (sessionId) üretir
  // ve User.activeSessionId'yi günceller. JwtAuthGuard payload.sid ile bu değeri
  // karşılaştırır; uyumsuzsa "başka bir cihazda giriş yapıldı" hatası döner.
  activeSessionId                 String?
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt
  deletedAt                       DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  examTests               ExamTest[]               @relation("educatorTests")
  purchases               Purchase[]               @relation("userPurchases")
  attempts                TestAttempt[]            @relation("userAttempts")
  notificationPreferences NotificationPreference[]
  createdDiscountCodes    DiscountCode[]           @relation("DiscountCodeCreatedBy")
  reportedObjections      Objection[]              @relation("ObjectionReporter")
  adminAnsweredObjections Objection[]              @relation("ObjectionAdminAnswerer")
  contractAcceptances     ContractAcceptance[]
  userPreference          UserPreference?
  adPurchases             AdPurchase[]             @relation("educatorAdPurchases")
  adImpressions           AdImpression[]           @relation("AdImpressionEducator")
  viewedAdImpressions     AdImpression[]           @relation("AdImpressionViewer")
  workerPermission        WorkerPermission?
  testPackages            TestPackage[]            @relation("educatorPackages")
  drafts                  DraftSnapshot[]          @relation("userDrafts")
  anomalyEvents           AttemptAnomalyEvent[]    @relation("candidateAnomalyEvents")
  packageViews            PackageView[]            @relation("userPackageViews")
  liveSessions            LiveSession[]            @relation("EducatorLiveSessions")
  liveParticipations      LiveParticipant[]        @relation("UserLiveParticipations")
  emailLogs               EmailLog[]
  devices                 UserDevice[]
  triggeredBackups        BackupLog[]              @relation("backupActor")

  // ── İçerik Moderasyonu ──────────────────────────────────────────────────
  moderationResults    ModerationResult[]
  moderationViolations ModerationViolation[]
  moderationActions    ModerationAction[]
  educatorRiskScore    EducatorRiskScore?
  suspendedUntil       DateTime?
  isBanned             Boolean               @default(false)

  @@index([tenantId])
  @@index([twoFactorEnabled])
  @@map("users")
}

model UserPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// --- Doğrulanmamış Kayıt Bekleme Tablosu ---
// Kullanıcı email doğrulama tamamlayana kadar User tablosuna yazılmaz.
// Doğrulama linkine tıklanınca buradan User'a promote edilir.
// Aynı email/username ile yeni deneme: eski kayıt silinip yeni token üretilir.
model PendingRegistration {
  id                        String    @id @default(uuid())
  email                     String    @unique
  username                  String    @unique
  passwordHash              String
  firstName                 String?
  lastName                  String?
  role                      UserRole  @default(CANDIDATE)
  acceptedTermsContractId   String?
  acceptedPrivacyContractId String?
  verificationToken         String    @unique
  verificationTokenExpiresAt DateTime
  ip                        String?
  userAgent                 String?
  tenantId                  String?

  createdAt DateTime @default(now())

  @@index([verificationTokenExpiresAt])
  @@map("pending_registrations")
}

model ExamType {
  id          String          @id @default(uuid())
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  slug        String          @unique
  active      Boolean         @default(true)
  topics      TopicExamType[]

  tests ExamTest[]

  @@map("exam_types")
}

// --- Sınav / Test Modülü ---

model Topic {
  id        String   @id @default(uuid())
  name      String
  slug      String
  active    Boolean  @default(true)
  parentId  String?
  createdAt DateTime @default(now())

  parent    Topic?          @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Topic[]         @relation("TopicTree")
  examTypes TopicExamType[]
  tests     ExamTest[]

  @@map("topics")
}

model TopicExamType {
  topicId    String
  examTypeId String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  examType   ExamType @relation(fields: [examTypeId], references: [id], onDelete: Cascade)

  @@id([topicId, examTypeId])
  @@map("topic_exam_types")
}

model ExamTest {
  id                 String     @id @default(uuid())
  title              String
  examTypeId         String?
  topicId            String?
  educatorId         String?
  isTimed            Boolean    @default(false)
  duration           Int? // minutes
  priceCents         Int? // price in cents (stage1 nullable)
  campaignPriceCents Int? // FR-E-04: süreli kampanya fiyatı
  campaignValidFrom  DateTime? // kampanya başlangıç
  campaignValidUntil DateTime? // kampanya bitiş
  currency           Currency   @default(TRY)
  campaignCurrency   Currency?
  questionCount      Int? // nullable for backfill in stage1
  hasSolutions       Boolean    @default(false)
  publishedAt        DateTime?
  status             TestStatus @default(DRAFT)
  metadata           Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @default(now()) @updatedAt
  deletedAt          DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Paketli/SaaS test motoru alanları
  packageId   String?
  package     TestPackage? @relation(fields: [packageId], references: [id])
  durationSec Int?

  questions ExamQuestion[]
  attempts  TestAttempt[]

  examType    ExamType?    @relation(fields: [examTypeId], references: [id], onDelete: SetNull)
  topic       Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
  educator    User?        @relation("educatorTests", fields: [educatorId], references: [id], onDelete: SetNull)
  Purchase    Purchase[]
  adPurchases AdPurchase[]

  @@index([tenantId])
  @@index([packageId])
  @@index([publishedAt])
  @@map("exam_tests")
}

model ExamQuestion {
  id               String           @id @default(uuid())
  testId           String
  content          String
  mediaUrl         String?
  order            Int              @default(0)
  solutionText     String?
  solutionMediaUrl String?
  moderationStatus ModerationStatus @default(PENDING_REVIEW)
  moderatedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  test       ExamTest        @relation(fields: [testId], references: [id], onDelete: Cascade)
  options    ExamOption[]
  answers    AttemptAnswer[]
  objections Objection[]

  @@map("exam_questions")
}

model ExamOption {
  id               String           @id @default(uuid())
  questionId       String
  content          String
  mediaUrl         String?
  isCorrect        Boolean          @default(false)
  moderationStatus ModerationStatus @default(PENDING_REVIEW)
  moderatedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  question   ExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedBy AttemptAnswer[]

  @@map("exam_options")
}

// Note: candidates are represented by `User` entries (role = CANDIDATE)

model TestAttempt {
  id          String        @id @default(uuid())
  testId      String
  candidateId String
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  submittedAt DateTime?
  status      AttemptStatus @default(IN_PROGRESS)
  score       Float?
  // autosave payload could be stored in metadata if needed
  metadata    Json?

  // Timer engine alanları
  lastResumedAt DateTime?
  pausedAt      DateTime?
  finishedAt    DateTime?
  remainingSec  Int?

  // Süre aşımı süresi (saniye).
  // Süreli testte aday izin verilen süreden sonra teslim ettiyse
  // kaç saniye geç teslim ettiği burada saklanır.
  // null → süre aşımı yok (zamanında teslim veya süreli olmayan test).
  overtimeSeconds Int?

  // Attempt başladığı andaki soru+seçenek+doğru cevap snapshot'ı (JSON).
  // Eğitici sonradan soruları güncellese bile bu attempt için orijinal versiyon korunur.
  questionsSnapshot Json?

  test          ExamTest              @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidate     User                  @relation("userAttempts", fields: [candidateId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]
  objections    Objection[]
  anomalyEvents AttemptAnomalyEvent[]

  @@unique([testId, candidateId])
  @@index([candidateId])
  @@index([testId])
  @@map("test_attempts")
}

model TestStats {
  id            String   @id @default(uuid())
  testId        String   @unique
  ratingAvg     Float?
  ratingCount   Int      @default(0)
  purchaseCount Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@map("test_stats")
}

model AttemptAnswer {
  id               String   @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  isCorrect        Boolean? // optional; can be computed/stored
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempt  TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   ExamOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId], name: "attemptId_questionId")
  @@map("attempt_answers")
}

model Purchase {
  id             String         @id @default(uuid())
  testId         String
  candidateId    String
  amountCents    Int?
  currency       Currency       @default(TRY)
  amountUsdCents Int? // USD normalize snapshot (reporting)
  status         PurchaseStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refundedAt     DateTime?
  expiredAt      DateTime?
  deletedAt      DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  test           ExamTest      @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidate      User          @relation("userPurchases", fields: [candidateId], references: [id], onDelete: Cascade)
  discountCodeId String?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)

  packageId String?
  package   TestPackage? @relation(fields: [packageId], references: [id])

  paymentProvider String? // "iyzico" | "google_pay" | "amazon_pay"

  // Sprint 14 — Mesafeli Satış Sözleşmesi acceptance snapshot. TKHK m.48 gereği
  // her satın alma için ön bilgilendirme + sözleşme onayı kanıtı saklanır.
  // ContractAcceptance tablosundan ayrı; bir satın alma satırı kendi içinde
  // tam delil zinciri taşır (sözleşme hangi versiyondu, ne zaman/kim/hangi IP).
  // distanceSaleContractId: kabul edilen Contract.id snapshot'ı (NOT FK — versiyon
  //                        ileride pasif olsa bile kayıt korunur; FK olsaydı
  //                        on-delete tehlikesi vardı).
  distanceSaleContractId       String?   @db.Uuid
  distanceSaleAcceptedAt       DateTime?
  distanceSaleAcceptedIp       String?
  distanceSaleAcceptedUserAgent String?

  // Satın alma anında paketin testlerinin + sorularının + seçeneklerinin
  // donmuş snapshot'ı. Eğitici sonradan içeriği güncellese bile bu adayın
  // attempt'ları daima bu snapshot'tan beslenir. Yeni satışlar canlı içeriği
  // snapshot olarak alır.
  // Şekil: Array<{
  //   testId: string;
  //   title?: string;
  //   isTimed?: boolean;
  //   duration?: number | null;        // dakika
  //   questions: Array<{
  //     id: string;
  //     content: string;
  //     mediaUrl: string | null;
  //     order: number;
  //     solutionText: string | null;
  //     solutionMediaUrl: string | null;
  //     options: Array<{
  //       id: string;
  //       content: string;
  //       mediaUrl: string | null;
  //       isCorrect: boolean;
  //     }>;
  //   }>;
  // }>
  testsSnapshot Json?

  @@unique([testId, candidateId])
  @@index([tenantId])
  @@map("purchases")
}

model TestPackage {
  id            String    @id @default(cuid())
  tenantId      String
  educatorId    String?
  title         String
  description   String?
  // Eğitici paket için kapak görseli yükler — TestPackageCard listesinde ve
  // TestDetail hero bölümünde gösterilir. Boşsa default gradient + BookOpen ikonu.
  coverImageUrl String?
  priceCents    Int
  currency      Currency  @default(TRY)
  difficulty    String    @default("medium")
  isActive      Boolean   @default(true)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // NOTE: PostgreSQL'de manuel olarak GENERATED ALWAYS AS (...) STORED tsvector
  // kolonu var: `search_vector`. Prisma generated column'a ALTER yapamadığı için
  // (Use ALTER TABLE ... DROP EXPRESSION hatası), bu alan şemadan çıkarıldı.
  // Erişim için $queryRaw kullanın (apps/backend/src/application/services/...
  // dosyalarındaki tsvector aramaları gibi).

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  educator  User?         @relation("educatorPackages", fields: [educatorId], references: [id], onDelete: SetNull)
  tests     ExamTest[]
  purchases Purchase[]
  views     PackageView[]

  @@index([tenantId])
  @@index([educatorId])
  @@map("test_packages")
}

// Paket görüntülenme olayı (event log).
//
// Kullanım hedefleri:
//  1. Eğitici dashboard — paket başına toplam / son N günkü görüntülenme.
//  2. Aday öneri sistemi — viewerId × packageId join'iyle aday ilgi profili.
//  3. Reklam hedefleme — bir paketi görüntüleyen kullanıcılara reklam.
//
// Tekilleştirme: TestDetail her açıldığında bir satır yazılır (saf log).
// "Tekil görüntülenme" istatistikleri agrega aşamada GROUP BY ile hesaplanır.
//
// Privacy:
//  - viewerId: oturum varsa userId, anonim ise null
//  - sessionId: anonim oturumun tekilleştirilmesi için
//  - ipHash: sha256(ip + günlük_salt) — ham IP saklanmaz, abuse koruması için
//  - referrer/userAgent: bot/kaynak analizi
model PackageView {
  id        String   @id @default(uuid())
  tenantId  String
  packageId String
  viewerId  String?
  sessionId String?  @db.VarChar(64)
  ipHash    String?  @db.VarChar(64)
  referrer  String?  @db.VarChar(500)
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  package TestPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  viewer  User?       @relation("userPackageViews", fields: [viewerId], references: [id], onDelete: SetNull)

  // Eğitici raporu: paket + zaman penceresi
  @@index([packageId, createdAt(sort: Desc)])
  // Aday öneri sistemi: aday + zaman
  @@index([viewerId, createdAt(sort: Desc)])
  // Tekil görüntülenme tespiti (aynı kullanıcı + paket)
  @@index([packageId, viewerId])
  @@index([tenantId])
  @@map("package_views")
}

enum FollowType {
  EDUCATOR
  EXAM_TYPE
}

model Follow {
  id                   String     @id @default(uuid())
  followerId           String
  followType           FollowType
  educatorId           String?
  examTypeId           String?
  notificationsEnabled Boolean    @default(true)
  createdAt            DateTime   @default(now())

  @@unique([followerId, educatorId])
  @@unique([followerId, examTypeId])
  @@index([followerId, followType])
  @@map("follows")
}

model NotificationPreference {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  emailEnabled            Boolean  @default(true)
  weeklyDigestEnabled     Boolean  @default(true)
  inactiveReminderEnabled Boolean  @default(true)
  unsubscribeToken        String   @unique
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// --- Audit Log - Kritik işlemler zorunlu loglanır ---
// Satın alma, İade, Fiyat değişimi, Publish, Unpublish
// AttemptAnswer defined above

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String
  entityId   String
  actorId    String?
  tenantId   String?
  actorEmail String?
  actorRole  String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model DiscountCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  percentOff  Int // 0-100
  maxUses     Int? // nullable unlimited
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true) // false = eğitici tarafından pasife alındı
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  createdById String?

  createdBy User?      @relation("DiscountCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  purchases Purchase[]

  @@map("discount_codes")
}

// Not: answerText, escalatedAt, ObjectionStatus için migrate ayrı çalıştırılacak (objection_answer_sla_status).
model Objection {
  id                 String          @id @default(uuid())
  attemptId          String
  questionId         String
  reporterId         String
  reason             String
  status             ObjectionStatus @default(OPEN)
  answerText         String?
  createdAt          DateTime        @default(now())
  answeredAt         DateTime?
  escalatedAt        DateTime?
  moderationResultId String?
  // Admin yanıtı — eğitici cevabı vermese de admin müdahale edip yazabilir
  adminAnswerText    String?
  adminAnsweredAt    DateTime?
  adminAnswererId    String?

  attempt       TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reporter      User         @relation("ObjectionReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  adminAnswerer User?        @relation("ObjectionAdminAnswerer", fields: [adminAnswererId], references: [id], onDelete: SetNull)

  @@map("objections")
}

enum RefundStatus {
  PENDING
  EDUCATOR_APPROVED
  EDUCATOR_REJECTED
  APPEAL_PENDING
  ESCALATED
  APPROVED
  REJECTED
}

model RefundRequest {
  id                String       @id @default(uuid())
  purchaseId        String       @unique
  candidateId       String
  educatorId        String
  testId            String
  reason            String?
  description       String?
  currency          Currency     @default(TRY)
  status            RefundStatus @default(PENDING)
  educatorDeadline  DateTime?
  educatorDecidedAt DateTime?
  appealReason      String?
  appealedAt        DateTime?
  decidedBy         String?
  decidedAt         DateTime?
  adminNotes        String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([candidateId])
  @@index([educatorId])
  @@index([testId])
  @@map("refund_requests")
}

model Review {
  id          String  @id @default(uuid())
  // Yeni model: review per-package per-candidate. testId provenance amacıyla
  // (hangi test bağlamından geldiği) saklanır — domain'de artık doğrudan kullanılmaz.
  packageId   String?
  testId      String?
  educatorId  String
  candidateId String

  // testRating opsiyonel: aday testi değerlendirmeden SADECE eğiticiyi (educatorRating)
  // puanlayabilir. Educator-only satırlar testRating = null taşır.
  testRating     Int?
  educatorRating Int?
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Bir aday bir paket için tek review yaratır
  @@unique([packageId, candidateId])
  @@index([packageId])
  @@index([educatorId])
  @@index([testId])
  @@map("reviews")
}

// --- Contracts (type başına tek active uygulama katmanında enforce edilir)
model Contract {
  id          String       @id @default(uuid()) @db.Uuid
  type        ContractType
  version     Int
  title       String
  content     String       @db.Text
  isActive    Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  acceptances ContractAcceptance[]

  @@unique([type, version])
  @@map("contracts")
}

model ContractAcceptance {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String // TEXT, users.id ile aynı tip (FK uyumu)
  contractId String   @db.Uuid
  acceptedAt DateTime @default(now())
  ip         String?
  userAgent  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([userId, contractId])
  @@index([contractId])
  @@index([userId])
  @@map("contract_acceptances")
}

// Kullanıcı cihaz kaydı — yeni cihazdan giriş uyarısı için kullanılır.
// fingerprint = sha256(userAgent + ip) — aynı kullanıcı + fingerprint çifti tekil.
// trusted=true olduğunda artık o cihazdan girişler uyarı tetiklemez.
// trustToken ile aday/eğitici e-postadaki "Bu bendim" linkini kullanarak cihazı doğrular.
model UserDevice {
  id                  String    @id @default(uuid())
  userId              String
  fingerprint         String
  userAgent           String?
  ip                  String?
  trusted             Boolean   @default(false)
  trustToken          String?   @unique
  trustTokenExpiresAt DateTime?
  firstSeenAt         DateTime  @default(now())
  lastSeenAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
  @@index([trustToken])
  @@map("user_devices")
}

model AdminSettings {
  id                               Int       @id @default(1)
  commissionPercent                Int       @default(20) // percent
  vatPercent                       Int       @default(18)
  // ── Kill switches ─────────────────────────────────────────────────────
  purchasesEnabled                 Boolean   @default(true) // Satış Durdur
  packageCreationEnabled           Boolean   @default(true) // Paket Durdur (test oluşturma)
  testPublishingEnabled            Boolean   @default(true) // Canlı Test Durdur (yayınlama)
  testAttemptsEnabled              Boolean   @default(true) // Test Durdur (çözüm başlatma)
  adPurchasesEnabled               Boolean   @default(true) // Reklam Satın Alma Durdur
  twoFactorSystemEnabled           Boolean   @default(false) // 2FA sistem geneli aç/kapat (admin kontrolü)
  minPackagePriceCents             Int       @default(100) // Minimum paket fiyatı (kuruş)
  maxDiscountPercent               Int       @default(50) // Eğiticinin tanımlayabileceği maksimum indirim oranı (%)
  // Google OAuth 2.0 Client ID — admin panelinden yönetilir. Boşken Google ile giriş devre dışı.
  // Not: Client ID gizli değildir (tarayıcıya açıkça gönderilir); env'deki GOOGLE_CLIENT_ID fallback olarak kullanılır.
  googleClientId                   String?
  // Cloudflare Turnstile (CAPTCHA) — admin panelinden yönetilir.
  // Boşken bot doğrulaması devre dışı (login/register'da widget render edilmez, backend CAPTCHA'yı atlar).
  // Site key tarayıcıya gönderilir (gizli değil); secret key sadece backend tarafında kullanılır.
  // Env'deki TURNSTILE_SECRET_KEY fallback olarak kullanılır (DB değeri öncelikli).
  turnstileSiteKey                 String?
  turnstileSecretKey               String?
  minQuestionsPerTest              Int       @default(1) // Test başına minimum soru sayısı
  maxQuestionsPerTest              Int       @default(100) // Test başına maksimum soru sayısı
  maxTestsPerPackage               Int       @default(10) // Paket başına maksimum test sayısı
  maxLiveQuestions                 Int       @default(50) // Canlı oturum başına maksimum soru sayısı
  // ── İçerik Moderasyonu ────────────────────────────────────────────────────
  moderationEnabled                Boolean   @default(true)
  moderationClaudeEnabled          Boolean   @default(true)
  moderationThresholds             Json      @default("{\"hate\":0.7,\"sexual\":0.6,\"violence\":0.7,\"selfHarm\":0.5,\"harassment\":0.7,\"illegal\":0.7,\"profanity\":0.6}")
  moderationAutoSuspendThreshold   Int       @default(80) // EducatorRiskScore.computedScore eşiği (0-100)
  moderationAutoBanThreshold       Int       @default(95)
  moderationModelText              String    @default("claude-haiku-4-5")
  moderationModelVision            String    @default("claude-sonnet-4-6")
  // ── Email trafiği kill switch grid ─────────────────────────────────
  emailEnabled                     Boolean   @default(true) // global master switch
  // Eğitici matrisi
  emailEducatorCriticalEnabled     Boolean   @default(true)
  emailEducatorNotifyEnabled       Boolean   @default(true)
  emailEducatorBulkEnabled         Boolean   @default(true)
  // Aday matrisi
  emailCandidateCriticalEnabled    Boolean   @default(true)
  emailCandidateNotifyEnabled      Boolean   @default(true)
  emailCandidateBulkEnabled        Boolean   @default(true)
  // Staff (admin/worker)
  emailStaffCriticalEnabled        Boolean   @default(true)
  emailStaffNotifyEnabled          Boolean   @default(true)
  // Operasyonel
  emailDailyCapPerUser             Int       @default(20) // tek kullanıcıya günlük max mail
  emailBounceRateAlertThreshold    Float     @default(0.02) // %2 üstü → admin alert
  emailRetentionDays               Int       @default(90) // body anonimleştirme süresi
  // Otomatik durdurma durumu (cron bunu set eder, admin manuel açar)
  emailBulkAutoPausedAt            DateTime?
  emailBulkAutoPausedReason        String?
  // ── Gönderim saat penceresi (quiet hours) ──────────────────────────
  // Pencere dışında oluşan mailler reddedilmez; pencere başına geciktirilerek kuyruğa atılır.
  emailSendWindowEnabled           Boolean   @default(false)
  emailSendWindowStartHour         Int       @default(9) // 0-23, dahil
  emailSendWindowEndHour           Int       @default(21) // 1-24, dahil değil
  emailSendWindowTimezone          String    @default("Europe/Istanbul")
  emailSendWindowAppliesToCritical Boolean   @default(false)
  // ── Yedekleme zamanlayıcısı ────────────────────────────────────────────
  // Cron expression formatı: standart 5 alan (dakika saat gün ay haftaGünü).
  // Boş veya backupEnabled=false ise scheduler register etmez.
  backupEnabled                    Boolean   @default(false)
  backupCronExpression             String? // örn: "0 3 * * *" (her gün 03:00)
  backupTargetDir                  String? // örn: "/var/backups/sinav-salonu"
  backupRetentionDays              Int       @default(2)
  updatedAt                        DateTime  @updatedAt

  @@map("admin_settings")
}

// Komisyon oranı değişiklik geçmişi — her oran değişiminde bir kayıt eklenir.
// Bir satın alma için geçerli oran: effectiveFrom <= purchase.createdAt ORDER BY effectiveFrom DESC LIMIT 1
model CommissionRateHistory {
  id                String   @id @default(uuid())
  commissionPercent Int
  effectiveFrom     DateTime
  note              String?
  createdAt         DateTime @default(now())

  @@index([effectiveFrom])
  @@map("commission_rate_history")
}

// Site / şirket bilgileri — ana sayfa ve footer, admin tarafından düzenlenir
model SiteSettings {
  id                Int      @id @default(1)
  siteName          String? // "Dal" / "Sınav Salonu"
  heroTitle         String? // "Sınavlara Güvenle Hazırlan"
  heroSubtitle      String?
  searchPlaceholder String?
  statTests         String? // "10.000+ Test"
  statEducators     String? // "500+ Eğitici"
  statCandidates    String? // "100.000+ Aday"
  statSuccessRate   String? // "%85 Başarı Oranı"
  footerDescription String?
  companyName       String?
  contactEmail      String?
  contactPhone      String?
  address           String?
  linkAbout         String? // Hakkımızda URL
  linkPrivacy       String? // Gizlilik politikası
  linkContact       String?
  linkPartnership   String? // İş ortaklığı
  linkSupport       String? // Yardım ve destek
  copyrightText     String? // "© 2024 Dal. Tüm hakları saklıdır."
  updatedAt         DateTime @updatedAt

  @@map("site_settings")
}

model AdPackage {
  id           String   @id @default(uuid())
  name         String
  durationDays Int
  impressions  Int
  priceCents   Int
  currency     Currency @default(TRY)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases AdPurchase[]

  @@map("ad_packages")
}

model AdPurchase {
  id                   String       @id @default(uuid())
  educatorId           String
  adPackageId          String
  // TEST: belirli bir paket öne çıkar; EDUCATOR: eğiticinin kendisi öne çıkar
  targetType           AdTargetType @default(TEST)
  // TEST türünde zorunlu; EDUCATOR türünde null olabilir
  testId               String?
  validUntil           DateTime
  impressionsRemaining Int          @default(0)
  // Şimdiye kadar gerçekleşen toplam gösterim sayısı
  impressionsDelivered Int          @default(0)
  currency             Currency     @default(TRY)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  canceledAt           DateTime?
  canceledReason       String?

  // Sprint 15 — Platform admin promo kodu uygulanmışsa snapshot.
  // Ödenen tutar (paidCents) reporting/audit için saklanır; AdPackage.priceCents
  // hâlâ baz fiyat olarak kalır. promoCodeId snapshot (FK) — promo silinse de
  // kayıt korunur.
  paidCents                    Int?
  platformPromoCodeId          String? @db.Uuid
  platformPromoDiscountCents   Int?

  educator    User           @relation("educatorAdPurchases", fields: [educatorId], references: [id], onDelete: Cascade)
  adPackage   AdPackage      @relation(fields: [adPackageId], references: [id], onDelete: Cascade)
  test        ExamTest?      @relation(fields: [testId], references: [id], onDelete: Cascade)
  impressions AdImpression[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([educatorId])
  @@index([testId])
  @@index([validUntil])
  @@map("ad_purchases")
}

// Her ana sayfa yüklemesinde gerçekleşen reklam gösterimini kaydeder.
// viewerUserId: giriş yapmış kullanıcı; null ise anonim ziyaretçi.
model AdImpression {
  id           String   @id @default(uuid())
  purchaseId   String
  educatorId   String
  testId       String?
  viewerUserId String?
  createdAt    DateTime @default(now())

  purchase AdPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  educator User       @relation("AdImpressionEducator", fields: [educatorId], references: [id])
  viewer   User?      @relation("AdImpressionViewer", fields: [viewerUserId], references: [id])

  @@index([purchaseId])
  @@index([educatorId])
  @@index([createdAt])
  @@map("ad_impressions")
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  plan               String
  status             SubscriptionStatus @default(ACTIVE)
  startedAt          DateTime
  endsAt             DateTime?
  kind               SubscriberKind     @default(TENANT)
  subscriberId       String // educatorId veya tenantId — kind'a göre
  tier               SubscriptionTier   @default(FREE)
  providerRef        String?            @unique // Stripe Subscription ID
  customerRef        String? // Stripe Customer ID
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([kind, subscriberId])
  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  userId       String
  route        String
  key          String
  requestHash  String?
  status       String // IN_PROGRESS | COMPLETED
  responseCode Int?
  responseBody Json?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([userId, route, key])
  @@index([expiresAt])
  @@index([userId, route])
}

// Webhook replay koruması — payment provider event'leri idempotent işlenir
model WebhookEvent {
  id              String    @id @default(cuid())
  provider        String // 'stripe' | 'iyzico'
  providerEventId String
  payload         Json
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  error           String?

  @@unique([provider, providerEventId])
  @@index([receivedAt(sort: Desc)])
  @@map("webhook_events")
}

// Ödeme sağlayıcı ayarları — admin panelinden yönetilir
model PaymentSettings {
  id                  Int      @id @default(1)
  mode                String   @default("test") // "test" | "live"
  iyzicoEnabled       Boolean  @default(true)
  iyzicoApiKey        String?
  iyzicoSecretKey     String?
  iyzicoBaseUrl       String   @default("https://sandbox-api.iyzipay.com")
  googlePayEnabled    Boolean  @default(true)
  googlePayMerchantId String?
  amazonPayEnabled    Boolean  @default(true)
  amazonPayMerchantId String?
  companyName         String?
  companyTaxId        String?
  companyAddress      String?
  updatedAt           DateTime @updatedAt

  @@map("payment_settings")
}

// ── Live Session Modülleri ────────────────────────────────────────────────────

model LiveSessionTier {
  id              String        @id @default(uuid())
  label           String
  minParticipants Int           @default(0)
  maxParticipants Int?
  priceCents      Int           @default(0)
  isActive        Boolean       @default(true)
  order           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sessions        LiveSession[]

  @@map("live_session_tiers")
}

model LiveSession {
  id                      String    @id @default(uuid())
  educatorId              String
  tierId                  String?
  maxParticipants         Int?
  currentParticipantCount Int       @default(0) @map("current_participant_count")
  title                   String
  joinCode                String    @unique
  status                  String    @default("DRAFT")
  currentQuestionIdx      Int       @default(0)
  showStats               Boolean   @default(false)
  paidAt                  DateTime?
  startedAt               DateTime?
  endedAt                 DateTime?
  roundNumber             Int       @default(1)
  parentSessionId         String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Sprint 15 — Platform admin promo kodu uygulanmışsa snapshot.
  // Tier.priceCents baz fiyat; ödenen tutar paidCents'te. Reporting + audit için.
  paidCents                    Int?
  platformPromoCodeId          String? @db.Uuid
  platformPromoDiscountCents   Int?

  educator     User              @relation("EducatorLiveSessions", fields: [educatorId], references: [id])
  tier         LiveSessionTier?  @relation(fields: [tierId], references: [id])
  questions    LiveQuestion[]
  participants LiveParticipant[]
  parent       LiveSession?      @relation("LiveSessionRounds", fields: [parentSessionId], references: [id])
  rounds       LiveSession[]     @relation("LiveSessionRounds")

  @@index([educatorId])
  @@index([parentSessionId])
  @@map("live_sessions")
}

model LiveQuestion {
  id        String   @id @default(uuid())
  sessionId String
  content   String
  mediaUrl  String?
  order     Int
  createdAt DateTime @default(now())

  session LiveSession  @relation(fields: [sessionId], references: [id])
  options LiveOption[]
  answers LiveAnswer[]

  @@index([sessionId])
  @@map("live_questions")
}

model LiveOption {
  id         String  @id @default(uuid())
  questionId String
  content    String
  mediaUrl   String?
  isCorrect  Boolean
  order      Int

  question LiveQuestion @relation(fields: [questionId], references: [id])
  answers  LiveAnswer[]

  @@index([questionId])
  @@map("live_options")
}

model LiveParticipant {
  id         String   @id @default(uuid())
  sessionId  String
  userId     String
  joinedAt   DateTime @default(now())
  lastSeenAt DateTime @default(now())

  session LiveSession  @relation(fields: [sessionId], references: [id])
  user    User         @relation("UserLiveParticipations", fields: [userId], references: [id])
  answers LiveAnswer[]

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([sessionId, lastSeenAt])
  @@map("live_participants")
}

model LiveAnswer {
  id            String   @id @default(uuid())
  sessionId     String
  questionId    String
  participantId String
  optionId      String?
  answeredAt    DateTime @default(now())

  question    LiveQuestion    @relation(fields: [questionId], references: [id])
  option      LiveOption?     @relation(fields: [optionId], references: [id])
  participant LiveParticipant @relation(fields: [participantId], references: [id])

  @@unique([questionId, participantId])
  @@index([sessionId])
  @@map("live_answers")
}

// Worker rolü: sınırlı admin; hangi sayfalara erişebildiği burada saklanır
model WorkerPermission {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages     String[] // izin verilen sayfa adları, örn: ["AdminDashboard","ManageTests"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("worker_permissions")
}

// ── Email Trafiği Modülü ────────────────────────────────────────────────

// Mail sağlayıcı yapılandırması — admin panelinden yönetilir.
// API key/SMTP şifre AES-256-GCM ile şifrelenerek encryptedSecrets içinde saklanır.
model EmailProviderConfig {
  id                String            @id @default(cuid())
  tenantId          String
  name              String
  kind              EmailProviderKind
  priority          Int               @default(100)
  isActive          Boolean           @default(true)
  fromEmail         String
  fromName          String
  replyToEmail      String?
  encryptedSecrets  String // AES-256-GCM encrypted JSON
  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  lastFailureReason String?
  dailySentCount    Int               @default(0)
  dailyResetAt      DateTime          @default(now())
  dailyCap          Int?
  webhookSecret     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@index([tenantId, isActive, priority])
  @@map("email_provider_configs")
}

// Mail şablonu kaydı — dosya tabanlı template'ler için meta + versiyonlama.
model EmailTemplate {
  id           String     @id @default(cuid())
  tenantId     String
  key          String
  version      Int        @default(1)
  subject      String
  htmlPath     String
  textPath     String?
  defaultQueue EmailQueue
  isActive     Boolean    @default(true)
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, version])
  @@index([tenantId, key, isActive])
  @@map("email_templates")
}

// Tek bir mail gönderiminin merkezi log kaydı.
// KVKK: body alanları retentionDays (varsayılan 90) sonra cron tarafından null'lanır.
model EmailLog {
  id                String             @id @default(cuid())
  tenantId          String
  recipientUserId   String?
  recipientEmail    String
  recipientRole     UserRole?
  templateKey       String
  templateVersion   Int
  queue             EmailQueue
  status            EmailStatus        @default(QUEUED)
  subject           String
  htmlBody          String?
  textBody          String?
  templateData      Json?
  providerConfigId  String?
  providerKind      EmailProviderKind?
  providerMessageId String?
  attemptCount      Int                @default(0)
  lastErrorMessage  String?
  lastErrorCode     String?
  queuedAt          DateTime           @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  bouncedAt         DateTime?
  relatedEntityType String?
  relatedEntityId   String?

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient      User?                @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)
  providerConfig EmailProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  events         EmailEvent[]

  @@index([tenantId, recipientUserId, queuedAt])
  @@index([tenantId, status, queuedAt])
  @@index([tenantId, queue, status, queuedAt])
  @@index([tenantId, templateKey, queuedAt])
  @@index([providerMessageId])
  @@map("email_logs")
}

// Mail yaşam döngüsü olayları (queue, send, delivered, bounce, vb.).
model EmailEvent {
  id         String         @id @default(cuid())
  tenantId   String
  emailLogId String
  eventType  EmailEventType
  occurredAt DateTime       @default(now())
  source     String
  meta       Json?

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([tenantId, emailLogId, occurredAt])
  @@index([tenantId, eventType, occurredAt])
  @@map("email_events")
}

// Engellenmiş alıcı adresleri — bounce/spam/unsubscribe sonrası otomatik veya manuel.
model SuppressedEmail {
  id        String            @id @default(cuid())
  tenantId  String
  email     String
  reason    SuppressionReason
  source    String
  note      String?
  createdBy String?
  createdAt DateTime          @default(now())
  expiresAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId, reason])
  @@index([tenantId, expiresAt])
  @@map("suppressed_emails")
}

// ── İçerik Moderasyonu ───────────────────────────────────────────────────────

model BlockedTerm {
  id        String             @id @default(uuid())
  tenantId  String
  term      String // normalize edilmiş literal
  pattern   String? // opsiyonel regex
  category  ModerationCategory
  severity  Int                @default(1) // 1-5
  isActive  Boolean            @default(true)
  createdBy String? // admin userId
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, term])
  @@index([tenantId, isActive])
  @@index([tenantId, category])
  @@map("blocked_terms")
}

model ModerationResult {
  id             String               @id @default(uuid())
  tenantId       String
  userId         String // içeriği yükleyen kullanıcı (educatorId)
  entityType     String // "ExamQuestion" | "ExamOption" | "ExamTest" | "Review"
  entityId       String
  provider       ModerationProvider
  status         ModerationStatus
  score          Float? // tek skor (geriye uyum için)
  scores         Json? // { hate: 0.1, sexual: 0.8, ... }
  categories     ModerationCategory[]
  matchedTerms   String[]             @default([]) // blocklist eşleşmeleri
  flaggedContent String?
  reasonText     String? // Claude reasoning veya açıklama
  reviewerNote   String?
  rawResponse    Json? // AI yanıtı (debug için)
  cost           Decimal?             @db.Decimal(10, 6)
  latencyMs      Int                  @default(0)
  createdAt      DateTime             @default(now())
  reviewedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@map("moderation_results")
}

model ModerationViolation {
  id                 String             @id @default(uuid())
  tenantId           String
  userId             String // educatorId
  moderationResultId String?
  category           ModerationCategory
  severity           Int                @default(1) // 1-5
  status             String             @default("OPEN") // OPEN | DISMISSED | CONFIRMED
  entityType         String
  entityId           String
  adminNote          String?
  reviewedBy         String?
  reviewedAt         DateTime?
  resolvedAt         DateTime?
  createdAt          DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, status, severity, createdAt])
  @@index([tenantId, category])
  @@map("moderation_violations")
}

model ModerationAction {
  id         String               @id @default(uuid())
  tenantId   String
  userId     String // aksiyon alınan kullanıcı
  actorId    String? // aksiyon alan admin/worker; null = otomatik
  actionType ModerationActionType
  reason     String?
  metadata   Json                 @default("{}")
  expiresAt  DateTime? // geçici askıya alma için
  createdAt  DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, actionType])
  @@map("moderation_actions")
}

model EducatorRiskScore {
  id                String            @id @default(uuid())
  tenantId          String
  userId            String            @unique
  riskLevel         EducatorRiskLevel @default(LOW)
  computedScore     Float             @default(0) // 0-100
  violationCount    Int               @default(0)
  openViolations    Int               @default(0)
  highSeverityCount Int               @default(0)
  lastViolationAt   DateTime?
  lastComputedAt    DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, riskLevel, computedScore])
  @@index([tenantId, lastViolationAt])
  @@map("educator_risk_scores")
}

// Sunucu tarafı draft yedeği. Eğitici test/paket oluştururken veya düzenlerken
// tarayıcı kapansa, localStorage temizlense ya da cihaz değişse bile devam
// edebilsin diye periyodik olarak buraya da yazılır.
//
// key: client tarafında üretilen mantıksal anahtar
//   - 'createTestWizard'                 → yeni paket oluşturma sihirbazı
//   - 'editTestWizard:{packageId}'       → mevcut paketi düzenleme
//
// Cron 7 günden eski draft'ları temizler. Başarılı kaydetme sonrası frontend
// DELETE çağırır.
model DraftSnapshot {
  id        String   @id @default(uuid())
  ownerId   String
  key       String
  payload   Json
  updatedAt DateTime @default(now()) @updatedAt
  createdAt DateTime @default(now())

  owner User @relation("userDrafts", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, key])
  @@index([updatedAt])
  @@map("draft_snapshots")
}

// Aday'ın test çözme oturumundaki anti-leak / anti-cheat olayları.
// Frontend proctoring hook'u (useTestProctoring) burada toplanan event'leri
// POST /attempts/:id/anomaly endpoint'i ile sunucuya iletir.
//
// type değerleri (string literal — enum yapmadık ki ileride eklenmesi migration
// gerektirmesin):
//   - TAB_SWITCH           sekme değiştirildi / pencere odağı kayboldu
//   - FULLSCREEN_EXIT      fullscreen'den çıkıldı
//   - CONTEXT_MENU         sağ tık denemesi
//   - COPY_ATTEMPT         Ctrl+C / copy event
//   - CUT_ATTEMPT          Ctrl+X / cut event
//   - PASTE_ATTEMPT        Ctrl+V / paste event
//   - PRINT_KEY            Ctrl+P / PrintScreen
//   - DEVTOOLS_HEURISTIC   pencere boyut farkından devtools açık tespiti
//   - SHORTCUT_BLOCKED     diğer engellenen kısayollar (Ctrl+S, Ctrl+A)
//   - RAPID_ANSWER         soru başlangıcından çok kısa sürede cevaplama
//   - HEADLESS_DETECTED    navigator.webdriver veya headless fingerprint
model AttemptAnomalyEvent {
  id          String   @id @default(uuid())
  attemptId   String
  candidateId String
  type        String
  payload     Json?
  createdAt   DateTime @default(now())

  attempt   TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  candidate User        @relation("candidateAnomalyEvents", fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([attemptId, type])
  @@index([candidateId, createdAt])
  @@map("attempt_anomaly_events")
}

// ── Yedekleme ────────────────────────────────────────────────────────────
enum BackupStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum BackupTrigger {
  SCHEDULED
  MANUAL
}

// pg_dump → gzip yedekleme audit log'u.
// AdminSettings.backupCronExpression ile zamanlanır; admin panelinden manuel
// de tetiklenebilir. Retention için tek başına yetmez — dosyalar diskte
// silinince log kaydı (status SUCCESS) referans için tutulur.
model BackupLog {
  id           String        @id @default(uuid())
  tenantId     String
  trigger      BackupTrigger
  status       BackupStatus  @default(RUNNING)
  scheduledAt  DateTime      @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  sizeBytes    BigInt?
  targetPath   String? // tam dosya yolu
  fileName     String? // sadece dosya adı (UI için)
  actorId      String? // MANUAL ise tetikleyen admin
  errorMessage String?
  errorStack   String?
  createdAt    DateTime      @default(now())

  actor User? @relation("backupActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@map("backup_logs")
}

// ---------------------------------------------------------------------------
// Sprint 15 — Platform Admin Promo Code (LIVE_SESSION + AD_PACKAGE scope)
// ---------------------------------------------------------------------------
// Eğitici canlı test (LiveSession) ve reklam paketi (AdPurchase) satın alırken
// kullanabileceği admin-tarafından oluşturulmuş promosyon kodu.
//
// Mevcut `DiscountCode` modelinden FARKLI:
//   - DiscountCode      : educator → candidate (paket alımı için eğitici tarafından üretilir)
//   - PlatformPromoCode : admin → educator (canlı test + reklam paketi için)
// İki kavram ayrı tabloda; yetki/scope açık.
// ---------------------------------------------------------------------------

enum PlatformPromoScope {
  LIVE_SESSION  // Eğitici canlı test ödemesinde
  AD_PACKAGE    // Eğitici reklam paketi ödemesinde
}

model PlatformPromoCode {
  id          String               @id @default(uuid()) @db.Uuid
  code        String               @unique
  description String?
  percentOff  Int                  // 1-100
  scopes      PlatformPromoScope[] // hangi akışlarda geçerli (birden fazla olabilir)
  maxUses     Int?                 // null = sınırsız
  usedCount   Int                  @default(0)
  validFrom   DateTime?
  validUntil  DateTime?
  isActive    Boolean              @default(true)
  createdById String?              // admin userId — denormalize, FK on-delete tehlikeli
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  usages PlatformPromoCodeUsage[]

  @@index([code])
  @@index([isActive, validUntil])
  @@map("platform_promo_codes")
}

// Her kullanımı kaydeder. Unique constraint sayesinde aynı eğitici aynı kodu
// aynı purchase'da iki kez kullanamaz. Race condition koruması için Promo
// kullanımı her zaman bir transaction içinde `usedCount++` ile yapılır.
model PlatformPromoCodeUsage {
  id           String   @id @default(uuid()) @db.Uuid
  promoCodeId  String   @db.Uuid
  educatorId   String
  purchaseType String   // 'LIVE_SESSION' | 'AD_PACKAGE'
  purchaseId   String   // liveSessionId veya adPurchaseId
  discountCents Int     // hesaplanan indirim tutarı (audit/reporting için)
  usedAt       DateTime @default(now())

  promoCode PlatformPromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, purchaseId])
  @@index([educatorId])
  @@index([purchaseId])
  @@map("platform_promo_code_usages")
}
