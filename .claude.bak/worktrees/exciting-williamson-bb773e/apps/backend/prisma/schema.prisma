// Prisma Schema - Dal
// Kritik işlemler $transaction ile atomic yapılır

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  ADMIN
  EDUCATOR
  CANDIDATE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_EDUCATOR_APPROVAL
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  TIMEOUT
}

enum TestStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum PurchaseStatus {
  ACTIVE
  REFUNDED
  EXPIRED
}

enum AuditAction {
  PURCHASE
  REFUND_REQUESTED
  REFUND_RESOLVED
  TEST_PUBLISHED
  TEST_UNPUBLISHED
  PRICE_CHANGED
  OBJECTION_CREATED
  OBJECTION_ANSWERED
  EDUCATOR_APPROVED
  EDUCATOR_SUSPENDED
  EDUCATOR_UNSUSPENDED
  DISCOUNT_CREATED
  REVIEW_CREATED
  SUBMIT_ATTEMPT
  SUBMIT_ANSWER
  NOTIFICATIONS_DISABLED
  EMAIL_SENT
  OBJECTION_ESCALATED
  EMAIL_FAILED
  REFUND_APPROVED
  REFUND_REJECTED
  REVIEW_UPSERTED
  EXAMTYPE_CREATED
  TOPIC_CREATED
  CONTRACT_ACCEPTED
  EDUCATOR_PROFILE_UPDATED
  EXAMTYPE_UPDATED
  EXAMTYPE_DELETED
  TOPIC_UPDATED
  TOPIC_DELETED
  CSP_VIOLATION
  SUSPICIOUS_RATE_LIMIT
}

enum ObjectionStatus {
  OPEN
  ANSWERED
  ESCALATED
}

enum ContractType {
  CANDIDATE
  EDUCATOR
}

// --- Multi-tenant foundation ---

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  examTests     ExamTest[]
  purchases     Purchase[]
  adPurchases   AdPurchase[]
  subscriptions Subscription[]
  testPackages  TestPackage[]

  @@map("tenants")
}

// --- Marketplace / Exam domain ---

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  username           String     @unique
  passwordHash       String
  role               UserRole   @default(CANDIDATE)
  status             UserStatus @default(ACTIVE)
  educatorApprovedAt DateTime?
  lastLoginAt        DateTime?
  metadata           Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  examTests               ExamTest[]               @relation("educatorTests")
  purchases               Purchase[]               @relation("userPurchases")
  attempts                TestAttempt[]            @relation("userAttempts")
  notificationPreferences NotificationPreference[]
  createdDiscountCodes    DiscountCode[]           @relation("DiscountCodeCreatedBy")
  reportedObjections      Objection[]              @relation("ObjectionReporter")
  contractAcceptances     ContractAcceptance[]
  userPreference          UserPreference?
  adPurchases             AdPurchase[]             @relation("educatorAdPurchases")

  @@index([tenantId])
  @@map("users")
}

model UserPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model ExamType {
  id          String   @id @default(uuid())
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slug        String   @unique
  active      Boolean  @default(true)
  topics      Topic[]

  tests ExamTest[]

  @@map("exam_types")
}

// --- Sınav / Test Modülü ---

model Topic {
  id         String     @id @default(uuid())
  examTypeId String
  examType   ExamType   @relation(fields: [examTypeId], references: [id])
  name       String
  slug       String
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  tests      ExamTest[]

  @@unique([examTypeId, slug])
  @@map("topics")
}

model ExamTest {
  id                 String     @id @default(uuid())
  title              String
  examTypeId         String?
  topicId            String?
  educatorId         String?
  isTimed            Boolean    @default(false)
  duration           Int? // minutes
  priceCents         Int? // price in cents (stage1 nullable)
  campaignPriceCents Int? // FR-E-04: süreli kampanya fiyatı
  campaignValidFrom  DateTime? // kampanya başlangıç
  campaignValidUntil DateTime? // kampanya bitiş
  currency           String?    @default("TRY")
  questionCount      Int? // nullable for backfill in stage1
  hasSolutions       Boolean    @default(false)
  publishedAt        DateTime?
  status             TestStatus @default(DRAFT)
  metadata           Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @default(now()) @updatedAt
  deletedAt          DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Paketli/SaaS test motoru alanları
  packageId   String?
  package     TestPackage? @relation(fields: [packageId], references: [id])
  durationSec Int?

  questions ExamQuestion[]
  attempts  TestAttempt[]

  examType    ExamType?    @relation(fields: [examTypeId], references: [id], onDelete: SetNull)
  topic       Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
  educator    User?        @relation("educatorTests", fields: [educatorId], references: [id], onDelete: SetNull)
  Purchase    Purchase[]
  adPurchases AdPurchase[]

  @@index([tenantId])
  @@index([packageId])
  @@index([publishedAt])
  @@map("exam_tests")
}

model ExamQuestion {
  id               String  @id @default(uuid())
  testId           String
  content          String
  order            Int     @default(0)
  solutionText     String?
  solutionMediaUrl String?

  test       ExamTest        @relation(fields: [testId], references: [id], onDelete: Cascade)
  options    ExamOption[]
  answers    AttemptAnswer[]
  objections Objection[]

  @@map("exam_questions")
}

model ExamOption {
  id         String  @id @default(uuid())
  questionId String
  content    String
  isCorrect  Boolean @default(false)

  question   ExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedBy AttemptAnswer[]

  @@map("exam_options")
}

// Note: candidates are represented by `User` entries (role = CANDIDATE)

model TestAttempt {
  id          String        @id @default(uuid())
  testId      String
  candidateId String
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  submittedAt DateTime?
  status      AttemptStatus @default(IN_PROGRESS)
  score       Float?
  // autosave payload could be stored in metadata if needed
  metadata    Json?

  // Timer engine alanları
  lastResumedAt DateTime?
  pausedAt      DateTime?
  finishedAt    DateTime?
  remainingSec  Int?

  test       ExamTest        @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidate  User            @relation("userAttempts", fields: [candidateId], references: [id], onDelete: Cascade)
  answers    AttemptAnswer[]
  objections Objection[]

  @@unique([testId, candidateId])
  @@index([candidateId])
  @@index([testId])
  @@map("test_attempts")
}

model TestStats {
  id            String   @id @default(uuid())
  testId        String   @unique
  ratingAvg     Float?
  ratingCount   Int      @default(0)
  purchaseCount Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@map("test_stats")
}

model AttemptAnswer {
  id               String   @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  isCorrect        Boolean? // optional; can be computed/stored
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempt  TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   ExamOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId], name: "attemptId_questionId")
  @@map("attempt_answers")
}

model Purchase {
  id          String         @id @default(uuid())
  testId      String
  candidateId String
  amountCents Int?
  currency    String         @default("TRY")
  status      PurchaseStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  deletedAt   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  test           ExamTest      @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidate      User          @relation("userPurchases", fields: [candidateId], references: [id], onDelete: Cascade)
  discountCodeId String?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)

  packageId String?
  package   TestPackage? @relation(fields: [packageId], references: [id])

  @@unique([testId, candidateId])
  @@index([tenantId])
  @@map("purchases")
}

model TestPackage {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  priceCents  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  tests     ExamTest[]
  purchases Purchase[]

  @@index([tenantId])
  @@map("test_packages")
}

enum FollowType {
  EDUCATOR
  EXAM_TYPE
}

model Follow {
  id                   String     @id @default(uuid())
  followerId           String
  followType           FollowType
  educatorId           String?
  examTypeId           String?
  notificationsEnabled Boolean    @default(true)
  createdAt            DateTime   @default(now())

  @@unique([followerId, educatorId])
  @@unique([followerId, examTypeId])
  @@index([followerId, followType])
  @@map("follows")
}

model NotificationPreference {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  emailEnabled            Boolean  @default(true)
  weeklyDigestEnabled     Boolean  @default(true)
  inactiveReminderEnabled Boolean  @default(true)
  unsubscribeToken        String   @unique
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// --- Audit Log - Kritik işlemler zorunlu loglanır ---
// Satın alma, İade, Fiyat değişimi, Publish, Unpublish
// AttemptAnswer defined above

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String
  entityId   String
  actorId    String?
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model DiscountCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  percentOff  Int // 0-100
  maxUses     Int? // nullable unlimited
  usedCount   Int       @default(0)
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  createdById String?

  createdBy User?      @relation("DiscountCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  purchases Purchase[]

  @@map("discount_codes")
}

// Not: answerText, escalatedAt, ObjectionStatus için migrate ayrı çalıştırılacak (objection_answer_sla_status).
model Objection {
  id          String          @id @default(uuid())
  attemptId   String
  questionId  String
  reporterId  String
  reason      String
  status      ObjectionStatus @default(OPEN)
  answerText  String?
  createdAt   DateTime        @default(now())
  answeredAt  DateTime?
  escalatedAt DateTime?

  attempt  TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reporter User         @relation("ObjectionReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("objections")
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

model RefundRequest {
  id          String       @id @default(uuid())
  purchaseId  String       @unique
  candidateId String
  testId      String
  reason      String?
  status      RefundStatus @default(PENDING)
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime     @default(now())

  @@index([candidateId])
  @@index([testId])
  @@map("refund_requests")
}

model Review {
  id          String @id @default(uuid())
  testId      String
  educatorId  String
  candidateId String

  testRating     Int
  educatorRating Int?
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([testId, candidateId])
  @@index([educatorId])
  @@index([testId])
  @@map("reviews")
}

// --- Contracts (type başına tek active uygulama katmanında enforce edilir)
model Contract {
  id          String       @id @default(uuid()) @db.Uuid
  type        ContractType
  version     Int
  title       String
  content     String       @db.Text
  isActive    Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  acceptances ContractAcceptance[]

  @@unique([type, version])
  @@map("contracts")
}

model ContractAcceptance {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String // TEXT, users.id ile aynı tip (FK uyumu)
  contractId String   @db.Uuid
  acceptedAt DateTime @default(now())
  ip         String?
  userAgent  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([userId, contractId])
  @@index([contractId])
  @@index([userId])
  @@map("contract_acceptances")
}

model AdminSettings {
  id                Int      @id @default(1)
  commissionPercent Int      @default(20) // percent
  vatPercent        Int      @default(18)
  purchasesEnabled  Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@map("admin_settings")
}

// Site / şirket bilgileri — ana sayfa ve footer, admin tarafından düzenlenir
model SiteSettings {
  id                Int      @id @default(1)
  siteName          String? // "Dal" / "Sınav Salonu"
  heroTitle         String? // "Sınavlara Güvenle Hazırlan"
  heroSubtitle      String?
  searchPlaceholder String?
  statTests         String? // "10.000+ Test"
  statEducators     String? // "500+ Eğitici"
  statCandidates    String? // "100.000+ Aday"
  statSuccessRate   String? // "%85 Başarı Oranı"
  footerDescription String?
  companyName       String?
  contactEmail      String?
  contactPhone      String?
  address           String?
  linkAbout         String? // Hakkımızda URL
  linkPrivacy       String? // Gizlilik politikası
  linkContact       String?
  linkPartnership   String? // İş ortaklığı
  linkSupport       String? // Yardım ve destek
  copyrightText     String? // "© 2024 Dal. Tüm hakları saklıdır."
  updatedAt         DateTime @updatedAt

  @@map("site_settings")
}

model AdPackage {
  id           String   @id @default(uuid())
  name         String
  durationDays Int
  impressions  Int
  priceCents   Int
  currency     String   @default("TRY")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases AdPurchase[]

  @@map("ad_packages")
}

model AdPurchase {
  id                   String   @id @default(uuid())
  educatorId           String
  adPackageId          String
  testId               String
  validUntil           DateTime
  impressionsRemaining Int      @default(0)
  createdAt            DateTime @default(now())

  educator  User      @relation("educatorAdPurchases", fields: [educatorId], references: [id], onDelete: Cascade)
  adPackage AdPackage @relation(fields: [adPackageId], references: [id], onDelete: Cascade)
  test      ExamTest  @relation(fields: [testId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([educatorId])
  @@index([testId])
  @@index([validUntil])
  @@map("ad_purchases")
}

model Subscription {
  id        String    @id @default(cuid())
  tenantId  String
  plan      String
  status    String // active, canceled, trialing
  startedAt DateTime
  endsAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("subscriptions")
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  userId       String
  route        String
  key          String
  requestHash  String?
  status       String   // IN_PROGRESS | COMPLETED
  responseCode Int?
  responseBody Json?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([userId, route, key])
  @@index([expiresAt])
  @@index([userId, route])
}
