{
  "name": "dal",
  "version": "1.0.0",
  "description": "Dal - Kod İnceleme ve Öneriler",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/nest/main.js",
    "start:dev": "set REDIS_DISABLED=1&& set NODE_ENV=development&& npx tsx watch src/index.ts",
    "start:ci": "NODE_ENV=test PORT=3001 node dist/nest/main.js",
    "start:worker": "node dist/infrastructure/queue/email.worker.js",
    "start:dlq": "node dist/infrastructure/queue/dlq.worker.js",
    "dev": "npx tsx watch src/index.ts",
    "test": "jest",
    "test:unit": "jest --runInBand --testPathPattern=tests/usecases|tests/cron",
    "test:unit:ci": "jest --runInBand --ci --coverage --coverageDirectory=./coverage --testPathPattern=tests/usecases|tests/cron",
    "test:integration": "jest --runInBand --testPathPattern=tests/integration",
    "test:smoke": "jest --runInBand",
    "test:in-container": "docker exec docker-backend-1 sh -c \"cd /usr/src/app && npm test\"",
    "test:in-container:contracts": "docker exec docker-backend-1 sh -c \"cd /usr/src/app && npm test -- contracts\"",
    "test:in-container:integration": "docker exec docker-backend-1 sh -c \"cd /usr/src/app && npm run test:integration\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:backfill": "ts-node apps/backend/scripts/backfill-question-count.ts",
    "db:backfill:price": "ts-node apps/backend/scripts/backfill-price-cents.ts",
    "db:preflight:stage2": "ts-node apps/backend/scripts/preflight-stage2-not-null.ts",
    "db:stage2:apply": "npm run db:preflight:stage2 && npx prisma migrate deploy",
    "admin:set-price": "ts-node apps/backend/scripts/admin-set-test-price.ts",
    "openapi:export": "NODE_ENV=development ts-node apps/backend/src/nest/swagger/export-openapi.ts"
  },
  "keywords": [
    "code-review",
    "suggestions",
    "dal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/schedule": "^6.0.0",
    "cron": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "@nestjs/throttler": "^6.0.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "helmet": "^6.0.0",
    "rxjs": "^7.8.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0",
    "bullmq": "^1.81.0",
    "ioredis": "^5.3.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@nestjs/testing": "^10.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^13.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.7.0",
    "supertest": "6.3.3",
    "@types/supertest": "^2.0.12",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.1"
  }
}
