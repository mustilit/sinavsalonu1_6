PORT=3000
NODE_ENV=development

# Rate limit: NODE_ENV=development veya THROTTLE_DISABLED=1 → 500 req/dk
# Production: 60 req/dk

# Veritabanı (Prisma - kritik işlemler transaction ile atomic)
# Local geliştirme (host üzerinde):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sinavsalonu_v2?schema=public
# Docker compose (container içinde):
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sinavsalonu_v2?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sinavsalonu_v2?schema=public

# JWT (Güvenlik Katmanı)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=604800

# Multi-tenant default tenant id (used in seed & local dev)
DEFAULT_TENANT_ID=dev-tenant
