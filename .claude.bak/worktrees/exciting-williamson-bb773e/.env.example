# Example environment variables for the monorepo
# Copy to .env and adjust for your environment

############################
# Database (Docker / Postgres)
############################

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sinavsalonu_v2

# Backend connection string (inside Docker network)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sinavsalonu_v2?schema=public

############################
# Backend security
############################

JWT_SECRET=change_me
JWT_EXPIRES_IN=604800

############################
# Frontend / API
############################

VITE_API_URL=http://127.0.0.1:3000

############################
# Docker / Network (optional)
############################

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis
NPM_REGISTRY=https://registry.npmjs.org

SLACK_WEBHOOK_URL=
